/// Per-booking agent commission earned by the hostel admin who onboarded the hostel.
/// Created when the student's booking fee clears. Becomes payable after a hold window.
model AgentCommission {
  id              String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bookingId       String                 @unique @map("booking_id") @db.Uuid
  agentId         String                 @map("agent_id") @db.Uuid
  hostelId        String                 @map("hostel_id") @db.Uuid
  amount          Decimal                @default(35) @db.Decimal(10, 2)
  status          AgentCommissionStatus  @default(pending)
  availableAt     DateTime               @map("available_at") @db.Timestamptz(6)
  paidOutAt       DateTime?              @map("paid_out_at") @db.Timestamptz(6)
  payoutId        String?                @map("payout_id") @db.Uuid
  notes           String?
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  booking         Booking                @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  payout          AgentPayout?           @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@index([agentId, status])
  @@map("agent_commissions")
}

/// Agent-initiated payout request that bundles available commissions for transfer.
/// Reviewed by super-admin and marked paid once the MoMo / bank transfer is sent.
model AgentPayout {
  id              String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  agentId         String              @map("agent_id") @db.Uuid
  amount          Decimal             @db.Decimal(10, 2)
  method          AgentPayoutMethod
  destination     Json                @default("{}")
  status          AgentPayoutStatus   @default(requested)
  reviewedBy      String?             @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime?           @map("reviewed_at") @db.Timestamptz(6)
  paidAt          DateTime?           @map("paid_at") @db.Timestamptz(6)
  transactionRef  String?             @map("transaction_ref") @db.VarChar
  rejectionReason String?             @map("rejection_reason")
  notes           String?
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  commissions     AgentCommission[]

  @@index([agentId, status])
  @@index([status])
  @@map("agent_payouts")
}

